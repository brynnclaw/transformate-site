---
---
<section id="founder" class="relative py-24 px-6">
  <div class="max-w-[900px] mx-auto">
    <!-- Section Indicator -->
    <div class="flex items-center gap-4 mb-10 reveal">
      <span class="font-mono text-[14px] text-forge-amber">05</span>
      <div class="flex-1 dotted-separator"></div>
    </div>

    <div class="founder-card reveal border border-border rounded-[13px] p-8 md:p-12 flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-10" style="background:rgba(242,244,245,0.04);backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);">
      <!-- Photo Placeholder -->
      <div class="w-[120px] h-[120px] rounded-full bg-surface-2 shrink-0 flex items-center justify-center">
        <svg class="w-12 h-12 text-tertiary" viewBox="0 0 24 24" fill="currentColor" opacity="0.5">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left">
        <h3 class="font-sans font-medium text-primary-text text-[18px] mb-1">Brynn Bendixen</h3>
        <p class="font-sans text-[14px] text-secondary-text mb-4">Founder, Transformate AI</p>
        <p class="font-sans text-[18px] text-warm-ivory leading-relaxed italic mb-6">
          "I built Transformate because I watched too many businesses pay for transformation they never received. Every engagement we take is a bet on our reputation — and we don't lose those."
        </p>
        <a href="https://linkedin.com/in/brynnbendixen" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-sans text-forge-amber text-[16px] no-underline hover:text-bright-amber transition-colors duration-200">
          LinkedIn <span class="text-[12px] transition-transform duration-200 hover:translate-x-[2px] hover:-translate-y-[2px]">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>

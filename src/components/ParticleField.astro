---
---
<div class="particle-field" id="particle-field">
  <canvas id="particle-canvas"></canvas>
</div>

<style>
  .particle-field {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }
  #particle-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // ─── CONFIG ───
  // Dense particle sphere like mazehq.com, adapted to amber palette
  // Reference has thousands of particles forming near-solid sphere — 3500 is minimum for density match
  const PARTICLE_COUNT = 3500;

  // Amber palette: bright amber core, deep amber edges, warm ivory highlights, muted gray dust
  const colorWeights = [
    { color: '#D4920A', weight: 30 },   // Forge Amber (dominant)
    { color: '#E5A100', weight: 25 },   // Bright Amber
    { color: '#A67208', weight: 20 },   // Deep Amber (edges)
    { color: '#F0E4D0', weight: 10 },   // Warm Ivory (highlights)
    { color: '#8888A0', weight: 10 },   // Muted gray (dust)
    { color: '#C47A08', weight: 5 },    // Mid amber
  ];

  function pickColor(): string {
    const total = colorWeights.reduce((s, c) => s + c.weight, 0);
    let r = Math.random() * total;
    for (const cw of colorWeights) {
      r -= cw.weight;
      if (r <= 0) return cw.color;
    }
    return colorWeights[0].color;
  }

  let width = 0;
  let height = 0;
  let scrollProgress = 0;
  let mouseX = 0.5;
  let mouseY = 0.5;

  // ─── RESIZE ───
  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  resize();
  window.addEventListener('resize', resize);

  // ─── SCROLL TRACKING ───
  window.addEventListener('scroll', () => {
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    scrollProgress = docHeight > 0 ? window.scrollY / docHeight : 0;
  }, { passive: true });

  // ─── MOUSE TRACKING ───
  window.addEventListener('mousemove', (e) => {
    mouseX = e.clientX / width;
    mouseY = e.clientY / height;
  }, { passive: true });

  // ─── PARTICLE DATA ───
  interface Particle {
    // Sphere coordinates (normalized -1 to 1)
    sx: number;
    sy: number;
    sz: number; // depth for size/alpha variation
    size: number;
    color: string;
    baseAlpha: number;
    orbitSpeed: number;
    orbitAngle: number;
    drift: number; // for terrain spread
    terrainPhase: number;
  }

  // ─── CREATE PARTICLES IN SPHERE DISTRIBUTION ───
  const particles: Particle[] = [];
  for (let i = 0; i < PARTICLE_COUNT; i++) {
    // Fibonacci sphere distribution for even coverage
    const phi = Math.acos(1 - 2 * (i + 0.5) / PARTICLE_COUNT);
    const theta = Math.PI * (1 + Math.sqrt(5)) * i;

    // Add some noise to break perfect uniformity
    const noise = 0.15;
    const sx = Math.sin(phi) * Math.cos(theta) + (Math.random() - 0.5) * noise;
    const sy = Math.sin(phi) * Math.sin(theta) + (Math.random() - 0.5) * noise;
    const sz = Math.cos(phi) + (Math.random() - 0.5) * noise;

    particles.push({
      sx, sy, sz,
      size: Math.random() < 0.6 ? Math.random() * 1.0 + 0.3 : Math.random() * 1.8 + 0.5,
      color: pickColor(),
      baseAlpha: Math.random() * 0.65 + 0.3,
      orbitSpeed: (Math.random() - 0.5) * 0.002,
      orbitAngle: Math.random() * Math.PI * 2,
      drift: (Math.random() - 0.5) * 0.8,
      terrainPhase: Math.random() * Math.PI * 2,
    });
  }

  // ─── ANIMATION LOOP ───
  let time = 0;
  const sphereRadius = Math.min(width, height) * 0.32;

  function draw() {
    time++;
    ctx.clearRect(0, 0, width, height);

    // Recalculate sphere radius on each frame (responsive)
    // Reference sphere fills ~65% of viewport — use larger multiplier
    const sRadius = Math.min(width, height) * 0.48;
    const centerX = width * 0.5;
    const centerY = height * 0.42;

    // Subtle rotation
    const rotY = time * 0.001; // slow Y-axis rotation
    const cosR = Math.cos(rotY);
    const sinR = Math.sin(rotY);

    // Mouse parallax for sphere
    const mxOff = (mouseX - 0.5) * 20;
    const myOff = (mouseY - 0.5) * 15;

    // Scroll morph factor: 0 = sphere, 1 = terrain
    const morphT = Math.min(scrollProgress * 2.5, 1);

    // ── AMBIENT GLOW behind sphere ──
    if (morphT < 0.8) {
      const glowAlpha = 0.12 * (1 - morphT);
      const grd = ctx.createRadialGradient(
        centerX + mxOff, centerY + myOff, sRadius * 0.15,
        centerX + mxOff, centerY + myOff, sRadius * 1.4
      );
      grd.addColorStop(0, `rgba(212,146,10,${glowAlpha})`);
      grd.addColorStop(0.4, `rgba(166,114,8,${glowAlpha * 0.5})`);
      grd.addColorStop(1, 'rgba(10,10,16,0)');
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, width, height);
    }

    // Terrain glow
    if (morphT > 0.2) {
      const tGlowAlpha = 0.05 * morphT;
      const tGrd = ctx.createRadialGradient(
        centerX, height * 0.85, 0,
        centerX, height * 0.85, width * 0.5
      );
      tGrd.addColorStop(0, `rgba(212,146,10,${tGlowAlpha})`);
      tGrd.addColorStop(1, 'rgba(10,10,16,0)');
      ctx.fillStyle = tGrd;
      ctx.fillRect(0, 0, width, height);
    }

    // ── DRAW PARTICLES ──
    for (const p of particles) {
      // Rotate sphere coordinates
      p.orbitAngle += p.orbitSpeed;
      const rx = p.sx * cosR - p.sz * sinR;
      const rz = p.sx * sinR + p.sz * cosR;
      const ry = p.sy;

      // Sphere screen position
      const depth = (rz + 1) / 2; // 0 = back, 1 = front
      const sphereX = centerX + rx * sRadius + mxOff * depth;
      const sphereY = centerY + ry * sRadius * 0.85 + myOff * depth; // slightly squashed

      // Terrain position (wide wave at bottom)
      const terrainSpread = width * 0.55;
      const terrainX = centerX + p.sx * terrainSpread + p.drift * terrainSpread * 0.5;
      const waveY = Math.sin(p.sx * Math.PI * 2.5 + time * 0.004 + p.terrainPhase) * 35;
      const terrainY = height * 0.85 + waveY + p.sy * 30;

      // Interpolate
      const px = sphereX * (1 - morphT) + terrainX * morphT;
      const py = sphereY * (1 - morphT) + terrainY * morphT;

      // Size: closer particles (front) are bigger
      const depthScale = morphT < 1 ? 0.5 + depth * 0.7 : 0.6 + Math.random() * 0.3;
      const sz = p.size * depthScale;

      // Alpha: twinkle + depth fade (back particles dimmer)
      const twinkle = 0.6 + 0.4 * Math.sin(time * 0.015 + p.orbitAngle * 10);
      const depthAlpha = morphT < 1 ? 0.3 + depth * 0.7 : 0.6;
      const alpha = p.baseAlpha * twinkle * depthAlpha;

      // Draw
      ctx.beginPath();
      ctx.arc(px, py, sz, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.globalAlpha = alpha;
      ctx.fill();
    }

    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);
</script>

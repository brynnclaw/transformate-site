---
import HudButton from './HudButton.astro';
---
<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center px-6 py-24">
  <div class="max-w-[820px] w-full text-center">
    <!-- Headline -->
    <h1 id="hero-heading" class="font-serif font-normal text-primary-text leading-none mb-6" style="font-size:clamp(48px,6vw,77px);">
      <span class="hero-word inline-block opacity-0" style="transform:translateY(80px)">We</span>
      <span class="hero-word inline-block opacity-0" style="transform:translateY(80px)">don't</span>
      <span class="hero-word inline-block opacity-0" style="transform:translateY(80px)">leave</span>
      <span class="hero-word inline-block opacity-0" style="transform:translateY(80px)">until</span>
      <span class="hero-word inline-block opacity-0" style="transform:translateY(80px)">it</span>
      <span class="hero-word hero-emphasis inline-block opacity-0" style="transform:translateY(80px)" data-scramble="works.">works.</span>
    </h1>

    <!-- Subtitle -->
    <p id="hero-subtitle" class="font-sans font-normal text-secondary-text leading-relaxed mb-10 mx-auto max-w-[620px] opacity-0" style="font-size:clamp(18px,1.5vw,27px);letter-spacing:0.27px;transform:translateY(40px);">
      We find the process that's costing you the most — and replace it with a system that runs without you. In weeks, not months.
    </p>

    <!-- CTAs -->
    <div id="hero-buttons" class="flex flex-wrap items-center justify-center gap-5 mb-16 opacity-0" style="transform:translateY(30px);">
      <HudButton text="Book a call" href="#cta" variant="primary" />
      <HudButton text="See what's broken" href="#whats-broken" variant="secondary" />
    </div>

    <!-- Stat Strip -->
    <div id="hero-stats" class="flex items-center justify-center gap-6 flex-wrap opacity-0">
      <span class="font-mono text-[14px] tracking-[0.5px] text-secondary-text">14 days average</span>
      <span class="w-[6px] h-[6px] rounded-full bg-border"></span>
      <span class="font-mono text-[14px] tracking-[0.5px] text-secondary-text">Fixed pricing</span>
      <span class="w-[6px] h-[6px] rounded-full bg-border"></span>
      <span class="font-mono text-[14px] tracking-[0.5px] text-secondary-text">No retainers</span>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0" id="hero-scroll-hint">
    <span class="font-mono text-[11px] tracking-[2px] text-tertiary uppercase">Scroll down</span>
    <svg width="12" height="20" viewBox="0 0 12 20" fill="none" class="text-tertiary animate-bounce">
      <path d="M6 0v16m0 0l5-5m-5 5l-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- Momentum Line -->
  <div class="momentum-line"></div>
</section>

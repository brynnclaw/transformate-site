---
---
<section id="proof" class="relative py-32 px-6">
  <div class="max-w-[1100px] mx-auto">
    <!-- Section Indicator -->
    <div class="flex items-center gap-4 mb-10 reveal">
      <span class="font-mono text-[14px] text-forge-amber">09</span>
      <div class="flex-1 dotted-separator"></div>
    </div>

    <!-- Heading -->
    <h2 class="font-serif font-normal text-primary-text leading-tight mb-16 text-center reveal" style="font-size:clamp(32px,3.5vw,45px);">
      Proof, not promises.
    </h2>

    <!-- Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <div class="text-center reveal">
        <div class="odometer font-mono font-medium text-forge-amber mb-2" style="font-size:clamp(32px,3vw,45px);" data-value="14"></div>
        <span class="font-sans text-[16px] text-secondary-text">days average deployment</span>
      </div>
      <div class="text-center reveal">
        <span class="stat-text font-mono font-medium text-forge-amber block mb-2" style="font-size:clamp(32px,3vw,45px);">Fixed</span>
        <span class="font-sans text-[16px] text-secondary-text">pricing on every engagement</span>
      </div>
      <div class="text-center reveal">
        <div class="odometer font-mono font-medium text-forge-amber mb-2" style="font-size:clamp(32px,3vw,45px);" data-value="100" data-suffix="%"></div>
        <span class="font-sans text-[16px] text-secondary-text">guarantee — we don't leave until it works</span>
      </div>
    </div>

    <!-- Arkon Badge -->
    <div class="text-center mb-12 reveal">
      <p class="font-sans text-[16px] text-secondary-text mb-2">Built by the team behind Arkon</p>
      <a href="https://github.com/arkon-ai/arkon" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-sans text-[14px] text-secondary-text hover:text-primary-text transition-colors duration-200 no-underline">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        Open-source AI governance platform
      </a>
    </div>

    <!-- Founding Client CTA -->
    <div class="border border-dashed border-border rounded-[13px] p-8 text-center reveal" style="background:rgba(242,244,245,0.04);backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);">
      <h3 class="font-serif font-normal text-primary-text text-[24px] leading-tight mb-4">
        First 10 founding clients get this spot.
      </h3>
      <p class="font-sans text-[16px] text-secondary-text mb-6">
        A testimonial from you, right here. In exchange: founding rate pricing and a case study.
      </p>
      <a href="#cta" class="font-sans text-forge-amber text-[16px] no-underline hover:text-bright-amber transition-colors duration-200">
        Book your call →
      </a>
    </div>
  </div>
</section>
